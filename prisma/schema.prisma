// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  WARNED
  SUSPENDED
  BANNED
}

enum GigStatus {
  POSTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
  DISPUTED
}

enum GigCategory {
  ACADEMIC_SUPPORT
  CAMPUS_ERRANDS
  CREATIVE_DIGITAL
  MARKETPLACE
  SERVICES
  OTHER
}

enum LocationMode {
  ONLINE
  ON_CAMPUS
  FLEXIBLE
}

enum ContactPreference {
  IN_APP
  WHATSAPP
  BOTH
}

enum MessageType {
  TEXT
  OFFER
  COUNTER_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
  SYSTEM
}

enum ReportReason {
  SCAM
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  UNPAID_WORK
  MISLEADING_PRICING
  FAKE_IDENTITY
  PROHIBITED_TASK
  ABUSE
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  GIG
  USER
  MESSAGE
}

enum FlagReason {
  NSFW_IMAGE
  SPAM
  GIBBERISH
  NO_REAL_TASK
}

enum FlagStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  NEW_MESSAGE
  GIG_RESPONSE
  GIG_STATUS_CHANGE
  NEW_REVIEW
  OFFER_RECEIVED
  OFFER_ACCEPTED
  OFFER_REJECTED
  SYSTEM_WARN
  GIG_SELECTED
}

model User {
  id              String     @id @default(cuid())
  name            String
  phone           String     @unique
  email           String?    @unique
  passwordHash    String
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)
  profileImage    String?
  college         String?
  department      String?
  year            String?
  bio             String?
  whatsappNumber  String?
  avgRating       Float      @default(0)
  ratingCount     Int        @default(0)
  completedGigs   Int        @default(0)
  responseTime    Int?       // avg response time in minutes
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  postedGigs      Gig[]             @relation("PosterGigs")
  workerGigs      Gig[]             @relation("WorkerGigs")
  applications    Application[]
  conversations   ConversationParticipant[]
  sentMessages    Message[]
  reviewsGiven    Review[]          @relation("ReviewerRelation")
  reviewsReceived Review[]          @relation("RevieweeRelation")
  reports         Report[]          @relation("ReporterRelation")
  reportedBy      Report[]          @relation("ReportedUserRelation")
  aiFlags         AIFlag[]
  notifications   Notification[]
  adminNotes      AdminNote[]

  @@map("users")
}

model Gig {
  id               String            @id @default(cuid())
  title            String
  description      String
  category         GigCategory
  budget           Float
  isNegotiable     Boolean           @default(false)
  deadline         DateTime
  isUrgent         Boolean           @default(false)
  locationMode     LocationMode      @default(ON_CAMPUS)
  contactPref      ContactPreference @default(IN_APP)
  status           GigStatus         @default(POSTED)
  isRepeat         Boolean           @default(false)
  viewCount        Int               @default(0)
  attachments      String[]          @default([])
  tags             String[]          @default([])

  posterId         String
  poster           User              @relation("PosterGigs", fields: [posterId], references: [id])

  workerId         String?
  worker           User?             @relation("WorkerGigs", fields: [workerId], references: [id])

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  completedAt      DateTime?
  expiresAt        DateTime?

  applications     Application[]
  conversations    Conversation[]
  reviews          Review[]
  reports          Report[]
  aiFlags          AIFlag[]

  @@map("gigs")
}

model Application {
  id          String   @id @default(cuid())
  gigId       String
  gig         Gig      @relation(fields: [gigId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  message     String?
  proposedPrice Float?
  proposedETA  DateTime?
  isSelected  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([gigId, userId])
  @@map("applications")
}

model Conversation {
  id           String    @id @default(cuid())
  gigId        String
  gig          Gig       @relation(fields: [gigId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastMessageAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User        @relation(fields: [senderId], references: [id])
  content        String
  type           MessageType @default(TEXT)
  offerPrice     Float?
  offerETA       DateTime?
  offerStatus    String?     // pending, accepted, rejected
  attachmentUrl  String?
  attachmentType String?     // IMAGE, PDF
  isRead         Boolean     @default(false)
  createdAt      DateTime    @default(now())

  reports        Report[]

  @@map("messages")
}

model Review {
  id         String   @id @default(cuid())
  gigId      String
  gig        Gig      @relation(fields: [gigId], references: [id])
  reviewerId String
  reviewer   User     @relation("ReviewerRelation", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User     @relation("RevieweeRelation", fields: [revieweeId], references: [id])
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([gigId, reviewerId])
  @@map("reviews")
}

model Report {
  id           String           @id @default(cuid())
  reason       ReportReason
  description  String?
  status       ReportStatus     @default(PENDING)
  targetType   ReportTargetType
  reporterId   String
  reporter     User             @relation("ReporterRelation", fields: [reporterId], references: [id])

  // Polymorphic targets
  gigId        String?
  gig          Gig?             @relation(fields: [gigId], references: [id])
  reportedUserId String?
  reportedUser User?            @relation("ReportedUserRelation", fields: [reportedUserId], references: [id])
  messageId    String?
  message      Message?         @relation(fields: [messageId], references: [id])

  adminNote    String?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("reports")
}

model AIFlag {
  id          String     @id @default(cuid())
  reason      FlagReason
  confidence  Float
  status      FlagStatus @default(PENDING)
  details     String?
  adminNote   String?
  reviewedAt  DateTime?

  gigId       String?
  gig         Gig?       @relation(fields: [gigId], references: [id])
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("ai_flags")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

model AdminNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  note      String
  createdBy String
  createdAt DateTime @default(now())

  @@map("admin_notes")
}
